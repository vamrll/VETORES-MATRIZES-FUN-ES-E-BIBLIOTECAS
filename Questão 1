programa
{
    funcao inicio()
    {
        real notas[5]
        inteiro i

        para(i = 0; i < 5; i++)
        {
            escreva("Digite a nota do aluno ", i + 1, ": ")
            leia(notas[i])
        }

        escreva("\nNotas armazenadas:\n")

        para(i = 0; i < 5; i++)
        {
            escreva("Aluno ", i + 1, ": ", notas[i], "\n")
        }
    }
}
