programa
{
    funcao real calcularMedia(real nota1, real nota2)
    {
        retorne (nota1 + nota2) / 2
    }

    funcao inicio()
    {
        real n1, n2, media

        escreva("Digite a primeira nota: ")
        leia(n1)

        escreva("Digite a segunda nota: ")
        leia(n2)

        media = calcularMedia(n1, n2)

        escreva("Media calculada: ", media)
    }
}
